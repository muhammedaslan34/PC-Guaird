<?xml version="1.0" encoding="UTF-8"?>
<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs">
  <Package
    Name="Child Agent"
    Manufacturer="PC Managment"
    Version="0.1.0"
    UpgradeCode="6D4D5A47-6A91-4A0D-A7E1-4B4A1C2F9F01"
    InstallerVersion="500"
    Scope="perMachine">
    <SummaryInformation Description="Child Agent Windows Service and tray companion" />
    <MajorUpgrade DowngradeErrorMessage="A newer version of Child Agent is already installed." />
    <MediaTemplate EmbedCab="yes" />

    <StandardDirectory Id="ProgramFiles64Folder">
      <Directory Id="INSTALLFOLDER" Name="Child Agent">
        <Component Id="ServiceComponent" Guid="*">
          <File Id="ServiceExe" Source="$(var.ServiceBinaryDir)\child-agent-service.exe" KeyPath="yes" />
          <ServiceInstall
            Id="ChildAgentServiceInstaller"
            Type="ownProcess"
            Name="child-agent-service"
            DisplayName="Child Agent Service"
            Description="Maintains pairing, backend connectivity, and command execution for the child device."
            Start="auto"
            Account="LocalSystem"
            ErrorControl="normal" />
          <ServiceControl
            Id="ChildAgentServiceController"
            Name="child-agent-service"
            Start="install"
            Stop="both"
            Remove="uninstall"
            Wait="yes" />
        </Component>

        <Component Id="TrayComponent" Guid="*">
          <File Id="TrayExe" Source="$(var.TrayBinaryDir)\child-agent-tray.exe" KeyPath="yes" />
        </Component>
      </Directory>
    </StandardDirectory>

    <Feature Id="Complete" Title="Child Agent" Level="1">
      <ComponentRef Id="ServiceComponent" />
      <ComponentRef Id="TrayComponent" />
    </Feature>
  </Package>
</Wix>
