{
  "name": "pc-managment",
  "private": true,
  "packageManager": "pnpm@10.33.2",
  "scripts": {
    "dev:backend": "turbo run dev --filter=backend",
    "dev:dashboard": "turbo run dev --filter=dashboard",
    "dev:child-agent": "turbo run dev --filter=child-agent",
    "build:dashboard": "turbo run build --filter=dashboard",
    "build:child-agent": "turbo run build --filter=child-agent",
    "test:backend": "turbo run test --filter=backend",
    "test:dashboard": "turbo run test --filter=dashboard",
    "test:child-agent": "turbo run test --filter=child-agent",
    "lint:backend": "turbo run lint --filter=backend",
    "lint:dashboard": "turbo run lint --filter=dashboard",
    "lint:child-agent": "turbo run lint --filter=child-agent"
  },
  "devDependencies": {
    "turbo": "^2.0.0"
  }
}
